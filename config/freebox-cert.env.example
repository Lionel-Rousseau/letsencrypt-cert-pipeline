# Freebox API credentials
# Do not commit the real file.

FREEBOX_APP_ID="fr.example.freebox.certdeploy"
FREEBOX_APP_TOKEN="REPLACE_WITH_FREEBOX_APP_TOKEN"

# Domain configured in Freebox OS and requested in Let's Encrypt
FREEBOX_DOMAIN="home.example.tld"

# Host/port used for final TLS verification.
# If this script runs inside LAN, external port verification may fail because of NAT loopback.
FREEBOX_HOST="home.example.tld"
FREEBOX_PORT="1688"

# Certbot certificate name under /etc/letsencrypt/live/<name>
LE_CERT_NAME="home.example.tld"

# Keep RSA for Freebox compatibility
FREEBOX_KEY_TYPE="rsa"
