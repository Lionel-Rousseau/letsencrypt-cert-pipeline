#!/usr/bin/env bash
set -euo pipefail

ENV_FILE="${ENV_FILE:-/root/.secrets/freebox/freebox-cert.env}"
WARN_DAYS="${WARN_DAYS:-30}"

source "$ENV_FILE"

: "${FREEBOX_DOMAIN:?missing FREEBOX_DOMAIN}"
: "${FREEBOX_HOST:=$FREEBOX_DOMAIN}"
: "${FREEBOX_PORT:=443}"

end_date="$(
  echo | openssl s_client \
    -connect "${FREEBOX_HOST}:${FREEBOX_PORT}" \
    -servername "$FREEBOX_DOMAIN" \
    2>/dev/null \
  | openssl x509 -noout -enddate \
  | cut -d= -f2
)"

end_ts="$(date -d "$end_date" +%s)"
now_ts="$(date +%s)"
days_left="$(( (end_ts - now_ts) / 86400 ))"

echo "$FREEBOX_DOMAIN certificate expires in $days_left days"

if (( days_left < WARN_DAYS )); then
  echo "WARNING: Freebox certificate expires in less than $WARN_DAYS days"
  exit 2
fi
